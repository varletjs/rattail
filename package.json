{
  "name": "rattail",
  "version": "1.8.3",
  "description": "A utilities library for front-end developers, lightweight and ts-friendly",
  "keywords": [
    "front-end developers",
    "lightweight",
    "ts-friendly",
    "utilities library"
  ],
  "bugs": {
    "url": "https://github.com/varletjs/rattail/issues"
  },
  "license": "MIT",
  "author": "haoziqaq <357229046@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varletjs/rattail.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "typesVersions": {
    "*": {
      "vite-plus": [
        "dist/vite-plus/index.d.mts"
      ],
      "axle": [
        "dist/axle/index.d.mts"
      ],
      "axle/use": [
        "dist/axle/use.d.mts"
      ],
      "axle/api": [
        "dist/axle/api.d.mts"
      ],
      "ruler-factory": [
        "dist/ruler-factory/index.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./vite-plus": {
      "types": "./dist/vite-plus/index.d.mts",
      "import": "./dist/vite-plus/index.mjs"
    },
    "./axle": {
      "types": "./dist/axle/index.d.mts",
      "import": "./dist/axle/index.mjs"
    },
    "./axle/use": {
      "types": "./dist/axle/use.d.mts",
      "import": "./dist/axle/use.mjs"
    },
    "./axle/api": {
      "types": "./dist/axle/api.d.mts",
      "import": "./dist/axle/api.mjs"
    },
    "./ruler-factory": {
      "types": "./dist/ruler-factory/index.d.mts",
      "import": "./dist/ruler-factory/index.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "clean": "rimraf node_modules dist",
    "dev": "vp test watch",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "vp fmt",
    "lint": "vp lint --fix",
    "prepare": "vp config --hooks-dir .vite-hooks",
    "release": "pnpm build && vr release",
    "test": "vp test run --coverage"
  },
  "dependencies": {
    "@configurajs/vite-plus": "0.2.2",
    "@varlet/axle": "1.0.2",
    "js-cookie": "3.0.5",
    "mitt": "3.0.1",
    "ruler-factory": "0.0.14",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@varlet/release": "^1.0.2",
    "@vitest/coverage-istanbul": "^4.1.0",
    "jsdom": "^25.0.1",
    "nano-staged": "0.8.0",
    "rimraf": "^6.0.1",
    "typescript": "5.3.3",
    "vite-plus": "0.1.16",
    "vitepress": "^1.4.1",
    "vitest": "$vitest"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.16",
      "vitest": "npm:@voidzero-dev/vite-plus-core@0.1.16"
    }
  }
}
