{
  "name": "rattail",
  "version": "2.0.3",
  "description": "A Vite+ oriented, AI Agent friendly front-end toolchain",
  "keywords": [
    "ai-agent",
    "cli",
    "presets",
    "toolchain",
    "typescript",
    "utilities",
    "vite-plus"
  ],
  "bugs": {
    "url": "https://github.com/varletjs/rattail/issues"
  },
  "license": "MIT",
  "author": "haoziqaq <357229046@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varletjs/rattail.git"
  },
  "bin": {
    "rt": "dist/cli/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "typesVersions": {
    "*": {
      "vite-plus": [
        "dist/vite-plus/index.d.mts"
      ],
      "axle": [
        "dist/axle/index.d.mts"
      ],
      "axle/use": [
        "dist/axle/use.d.mts"
      ],
      "axle/api": [
        "dist/axle/api.d.mts"
      ],
      "ruler": [
        "dist/ruler-factory/index.d.mts"
      ],
      "ruler-factory": [
        "dist/ruler-factory/index.d.mts"
      ],
      "cli": [
        "dist/cli/index.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./vite-plus": {
      "types": "./dist/vite-plus/index.d.mts",
      "import": "./dist/vite-plus/index.mjs"
    },
    "./axle": {
      "types": "./dist/axle/index.d.mts",
      "import": "./dist/axle/index.mjs"
    },
    "./axle/use": {
      "types": "./dist/axle/use.d.mts",
      "import": "./dist/axle/use.mjs"
    },
    "./axle/api": {
      "types": "./dist/axle/api.d.mts",
      "import": "./dist/axle/api.mjs"
    },
    "./ruler": {
      "types": "./dist/ruler-factory/index.d.mts",
      "import": "./dist/ruler-factory/index.mjs"
    },
    "./ruler-factory": {
      "types": "./dist/ruler-factory/index.d.mts",
      "import": "./dist/ruler-factory/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.mts",
      "import": "./dist/cli/index.mjs"
    }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "clean": "tsx src/cli/bin.ts clean",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "vp fmt",
    "lint": "vp lint --fix",
    "prepare": "vp config --hooks-dir .vite-hooks && tsx src/cli/bin.ts hook",
    "release": "pnpm build && tsx src/cli/bin.ts release",
    "test:watch": "vp test watch",
    "test": "vp test run --coverage"
  },
  "dependencies": {
    "@configurajs/vite-plus": "0.2.5",
    "@varlet/axle": "1.0.2",
    "@varlet/release": "^2.2.1",
    "api-farmer": "0.1.5",
    "commander": "^13.0.0",
    "js-cookie": "3.0.5",
    "mitt": "3.0.1",
    "rimraf": "^6.0.1",
    "ruler-factory": "0.0.14",
    "unconfig": "^7.5.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@vitest/coverage-istanbul": "^4.1.0",
    "jsdom": "^25.0.1",
    "oxc-minify": "^0.124.0",
    "tsx": "^4.21.0",
    "typescript": "5.3.3",
    "vite-plus": "0.1.16",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "$vitest"
  },
  "peerDependencies": {
    "@voidzero-dev/vite-plus-core": ">=0.1.16",
    "vite-plus": ">=0.1.16"
  },
  "peerDependenciesMeta": {
    "@voidzero-dev/vite-plus-core": {
      "optional": true
    },
    "vite-plus": {
      "optional": true
    }
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.16",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.16"
    }
  }
}
