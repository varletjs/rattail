{
  "name": "rattail",
  "version": "1.7.0",
  "description": "A utilities library for front-end developers, lightweight and ts-friendly",
  "keywords": [
    "front-end developers",
    "lightweight",
    "ts-friendly",
    "utilities library"
  ],
  "bugs": {
    "url": "https://github.com/varletjs/rattail/issues"
  },
  "license": "MIT",
  "author": "haoziqaq <357229046@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varletjs/rattail.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": "./dist/index.mjs",
  "scripts": {
    "build": "vp pack",
    "clean": "rimraf node_modules dist",
    "dev": "vp test watch",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "vp fmt",
    "lint": "vp lint",
    "prepare": "simple-git-hooks",
    "release": "pnpm build && vr release",
    "test": "vp test run --coverage"
  },
  "dependencies": {
    "js-cookie": "^3.0.5",
    "mitt": "^3.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@configurajs/vite-plus": "^0.1.9",
    "@types/node": "^22.8.1",
    "@varlet/release": "^1.0.2",
    "@vitest/coverage-istanbul": "^4.1.0",
    "jsdom": "^25.0.1",
    "nano-staged": "0.8.0",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.11.1",
    "typescript": "5.3.3",
    "vite": "^8.0.1",
    "vite-plus": "^0.1.16",
    "vitepress": "^1.4.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec nano-staged --allow-empty",
    "commit-msg": "pnpm exec vr commit-lint -p $1"
  },
  "nano-staged": {
    "*.{md}": "vp fmt --no-error-on-unmatched-pattern",
    "*.{ts}": [
      "vp fmt --no-error-on-unmatched-pattern",
      "vp lint --fix"
    ]
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0"
}
